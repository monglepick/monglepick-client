# ============================================================
# 몽글픽 클라이언트 환경변수 예시
# 이 파일을 복사하여 .env 또는 .env.local로 사용하세요.
# Vite 환경변수는 반드시 VITE_ 접두사가 필요합니다.
# ============================================================

# ── API 기본 URL ──
# 프로덕션: 실제 도메인 (예: https://api.monglepick.com)
# 개발: 빈 문자열 (Vite 프록시가 경로별로 분배)
VITE_API_BASE_URL=

# ── Spring Boot 백엔드 ──
# 인증, 포인트, 결제, 구독, 사용자 API를 처리하는 백엔드 서버
VITE_BACKEND_URL=http://localhost:8080

# ── AI Agent ──
# 채팅, 검색 등 AI 관련 API를 처리하는 에이전트 서버
VITE_AGENT_URL=http://localhost:8000

# ── OAuth 클라이언트 ID ──
# 각 소셜 로그인 제공자의 클라이언트 ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_KAKAO_CLIENT_ID=your-kakao-client-id
VITE_NAVER_CLIENT_ID=your-naver-client-id

# ── OAuth 리다이렉트 URI ──
# 소셜 로그인 후 콜백 URL의 기본 도메인
VITE_OAUTH_REDIRECT_BASE=http://localhost:5173

# ── Toss Payments ──
# Toss Payments 클라이언트 키 (공개 키)
VITE_TOSS_CLIENT_KEY=test_ck_your-toss-client-key
